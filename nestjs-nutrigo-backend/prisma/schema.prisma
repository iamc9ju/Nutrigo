generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  userId        String         @id @default(uuid()) @map("user_id") @db.Uuid
  email         String         @unique @map("email") @db.VarChar(100)
  passwordHash  String         @map("password_hash") @db.VarChar(255)
  phone         String?        @unique @map("phone") @db.VarChar(20)
  role          UserRole       @map("role")
  is2faEnabled  Boolean        @default(false) @map("is_2fa_enabled")
  twoFaSecret   String?        @map("two_fa_secret") @db.VarChar(100)
  createdAt     DateTime       @default(now()) @map("created_at")
  deletedAt     DateTime?      @map("deleted_at")
  nutritionist  Nutritionist?
  foodPartner   FoodPartner?
  refreshTokens RefreshToken[]
  chatMessages  ChatMessage[]
  patient       Patient?

  @@index([email])
  @@index([phone])
  @@map("users")
}

model Patient {
  patientId         String         @id @default(uuid()) @map("patient_id") @db.Uuid
  userId            String         @unique @map("user_id") @db.Uuid
  firstName         String         @map("first_name") @db.VarChar(100)
  lastName          String         @map("last_name") @db.VarChar(100)
  dateOfBirth       DateTime?      @map("date_of_birth") @db.Date
  gender            GenderType?    @map("gender")
  bloodType         String?        @map("blood_type") @db.VarChar(5)
  chronicDiseases   String[]       @map("chronic_diseases")
  isProfileComplete Boolean        @default(false) @map("is_profile_complete")
  deletedAt         DateTime?      @map("deleted_at")
  appointments      Appointment[]
  healthMetrics     HealthMetric[]
  user              User           @relation(fields: [userId], references: [userId], onDelete: Cascade)
  reviews           Review[]
  orders            Order[]

  @@map("patients")
}

model Nutritionist {
  nutritionistId          String                  @id @default(uuid()) @map("nutritionist_id") @db.Uuid
  userId                  String                  @unique @map("user_id") @db.Uuid
  firstName               String                  @map("first_name") @db.VarChar(100)
  lastName                String                  @map("last_name") @db.VarChar(100)
  licenseNumber           String?                 @unique @map("license_number") @db.VarChar(50)
  licenseDocumentUrl      String?                 @map("license_document_url") @db.VarChar(500)
  consultationFee         Decimal                 @default(500.00) @map("consultation_fee") @db.Decimal(10, 2)
  verificationStatus      VerificationStatus      @default(pending) @map("verification_status")
  verifiedAt              DateTime?               @map("verified_at")
  verifiedBy              String?                 @map("verified_by") @db.Uuid
  deletedAt               DateTime?               @map("deleted_at")
  createdAt               DateTime                @default(now()) @map("created_at")
  appointments            Appointment[]
  nutritionistLeaves      NutritionistLeave[]
  nutritionistSchedules   NutritionistSchedule[]
  nutritionistSpecialties NutritionistSpecialty[]
  user                    User                    @relation(fields: [userId], references: [userId], onDelete: Cascade)
  reviews                 Review[]

  @@map("nutritionists")
}

model HealthMetric {
  healthMetricId Int      @id @default(autoincrement()) @map("health_metric_id")
  patientId      String   @map("patient_id") @db.Uuid
  weightKg       Decimal? @map("weight_kg") @db.Decimal(5, 2)
  heightCm       Decimal? @map("height_cm") @db.Decimal(5, 2)
  bodyFatPercent Decimal? @map("body_fat_percent") @db.Decimal(4, 1)
  recordedAt     DateTime @default(now()) @map("recorded_at")
  patient        Patient  @relation(fields: [patientId], references: [patientId], onDelete: Cascade)

  @@map("health_metrics")
}

model RefreshToken {
  userId         String    @map("user_id") @db.Uuid
  secretHash     String    @unique @map("token_hash") @db.VarChar(255)
  deviceId       String?   @map("device_id") @db.VarChar(255)
  ipAddress      String?   @map("ip_address") @db.VarChar(45)
  userAgent      String?   @map("user_agent")
  expiresAt      DateTime  @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  revokedAt      DateTime? @map("revoked_at")
  family         String?   @map("family") @db.Uuid
  refreshTokenId String    @id @default(uuid()) @map("refresh_token_id") @db.Uuid
  usedAt         DateTime? @map("used_at")
  user           User      @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId])
  @@index([secretHash])
  @@index([family])
  @@map("refresh_tokens")
}

model Specialty {
  specialtyId   Int                     @id @default(autoincrement()) @map("specialty_id")
  name          String                  @db.VarChar(100)
  description   String?
  nutritionists NutritionistSpecialty[]

  @@map("specialties")
}

model NutritionistSpecialty {
  nutritionistId String       @map("nutritionist_id") @db.Uuid
  specialtyId    Int          @map("specialty_id")
  nutritionist   Nutritionist @relation(fields: [nutritionistId], references: [nutritionistId], onDelete: Cascade)
  specialty      Specialty    @relation(fields: [specialtyId], references: [specialtyId], onDelete: Cascade)

  @@id([nutritionistId, specialtyId])
  @@map("nutritionist_specialties")
}

model NutritionistSchedule {
  nutritionistScheduleId Int          @id @default(autoincrement()) @map("nutritionist_schedule_id")
  nutritionistId         String       @map("nutritionist_id") @db.Uuid
  dayOfWeek              Int          @map("day_of_week")
  startTime              String       @map("start_time")
  endTime                String       @map("end_time")
  isAvailable            Boolean      @default(true) @map("is_available")
  nutritionist           Nutritionist @relation(fields: [nutritionistId], references: [nutritionistId], onDelete: Cascade)

  @@unique([nutritionistId, dayOfWeek])
  @@map("nutritionist_schedules")
}

model NutritionistLeave {
  nutritionistLeaveId Int          @id @default(autoincrement()) @map("nutritionist_leave_id")
  nutritionistId      String       @map("nutritionist_id") @db.Uuid
  leaveDate           DateTime     @map("leave_date") @db.Date
  isFullDay           Boolean      @default(true) @map("is_full_day")
  newStartTime        String?      @map("new_start_time")
  newEndTime          String?      @map("new_end_time")
  nutritionist        Nutritionist @relation(fields: [nutritionistId], references: [nutritionistId], onDelete: Cascade)

  @@unique([nutritionistId, leaveDate])
  @@map("nutritionist_leaves")
}

model Review {
  reviewId       Int          @id @default(autoincrement()) @map("review_id")
  appointmentId  String       @unique @map("appointment_id") @db.Uuid
  patientId      String       @map("patient_id") @db.Uuid
  nutritionistId String       @map("nutritionist_id") @db.Uuid
  rating         Int
  comment        String?
  createdAt      DateTime     @default(now()) @map("created_at")
  nutritionist   Nutritionist @relation(fields: [nutritionistId], references: [nutritionistId], onDelete: Cascade)
  patient        Patient      @relation(fields: [patientId], references: [patientId], onDelete: Cascade)

  @@map("reviews")
}

model Appointment {
  appointmentId  String            @id @default(uuid()) @map("appointment_id") @db.Uuid
  patientId      String            @map("patient_id") @db.Uuid
  nutritionistId String            @map("nutritionist_id") @db.Uuid
  startTime      DateTime          @map("start_time")
  endTime        DateTime          @map("end_time")
  status         AppointmentStatus @default(pending)
  type           AppointmentType   @default(online)
  chargeId       String?           @unique @map("charge_id") @db.VarChar(100)
  createdAt      DateTime          @default(now()) @map("created_at")
  deletedAt      DateTime?         @map("deleted_at")
  amount         Decimal?          @map("amount") @db.Decimal(10, 2)
  qrCodeUrl      String?           @map("qr_code_url") @db.VarChar(500)
  nutritionist   Nutritionist      @relation(fields: [nutritionistId], references: [nutritionistId], onDelete: Cascade)
  patient        Patient           @relation(fields: [patientId], references: [patientId], onDelete: Cascade)
  chatRoom       ChatRoom?

  @@index([patientId])
  @@index([nutritionistId])
  @@map("appointments")
}

model ChatRoom {
  chatRoomId    String        @id @default(uuid()) @map("chat_room_id") @db.Uuid
  appointmentId String        @unique @map("appointment_id") @db.Uuid
  createdAt     DateTime      @default(now()) @map("created_at")
  appointment   Appointment   @relation(fields: [appointmentId], references: [appointmentId], onDelete: Cascade)
  messages      ChatMessage[]

  @@map("chat_rooms")
}

model ChatMessage {
  chatMessageId String      @id @default(uuid()) @map("chat_message_id") @db.Uuid
  chatRoomId    String      @map("chat_room_id") @db.Uuid
  senderId      String      @map("sender_id") @db.Uuid
  message       String      @db.Text
  type          MessageType @default(text)
  createdAt     DateTime    @default(now()) @map("created_at")
  chatRoom      ChatRoom    @relation(fields: [chatRoomId], references: [chatRoomId], onDelete: Cascade)
  sender        User        @relation(fields: [senderId], references: [userId], onDelete: Cascade)

  @@map("chat_messages")
}

model FoodPartner {
  foodPartnerId  Int      @id @default(autoincrement()) @map("food_partner_id")
  userId         String   @unique @map("user_id") @db.Uuid
  partnerName    String   @map("partner_name") @db.VarChar(100)
  description    String?  @db.Text
  address        String?  @db.Text
  commissionRate Decimal  @default(15.00) @map("commission_rate") @db.Decimal(4, 2)
  isActive       Boolean  @default(true) @map("is_active")
  joinedAt       DateTime @default(now()) @map("joined_at")

  // Relations
  menuItems MenuItem[]
  user      User       @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("food_partners")
}

model MenuItem {
  menuItemId    Int      @id @default(autoincrement()) @map("menu_item_id")
  foodPartnerId Int      @map("food_partner_id")
  name          String   @db.VarChar(100)
  description   String?  @db.Text
  price         Decimal  @db.Decimal(10, 2)
  category      String?  @db.VarChar(50)
  imageUrl      String?  @map("image_url") @db.VarChar(255)
  caloriesKcal  Int?     @map("calories_kcal")
  proteinG      Decimal? @map("protein_g") @db.Decimal(5, 2)
  carbsG        Decimal? @map("carbs_g") @db.Decimal(5, 2)
  fatG          Decimal? @map("fat_g") @db.Decimal(5, 2)
  stockQuantity Int      @default(100) @map("stock_quantity")
  isOutOfStock  Boolean  @default(false) @map("is_out_of_stock")
  isAvailable   Boolean  @default(true) @map("is_available")

  // Relations
  foodPartner FoodPartner @relation(fields: [foodPartnerId], references: [foodPartnerId], onDelete: Cascade)
  orderItems  OrderItem[]

  @@map("menu_items")
}

model Order {
  orderId         String        @id @default(uuid()) @map("order_id") @db.Uuid
  patientId       String        @map("patient_id") @db.Uuid
  totalAmount     Decimal       @map("total_amount") @db.Decimal(10, 2)
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(UNPAID)
  deliveryAddress String        @map("delivery_address") @db.Text
  contactPhone    String        @map("contact_phone") @db.VarChar(20)
  chargeId        String?       @unique @map("charge_id") @db.VarChar(100)
  qrCodeUrl       String?       @map("qr_code_url") @db.VarChar(500)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // Relations
  patient Patient     @relation(fields: [patientId], references: [patientId], onDelete: Cascade)
  items   OrderItem[]

  @@index([patientId])
  @@map("orders")
}

model OrderItem {
  orderItemId  Int     @id @default(autoincrement()) @map("order_item_id")
  orderId      String  @map("order_id") @db.Uuid
  menuItemId   Int     @map("menu_item_id")
  quantity     Int
  priceAtOrder Decimal @map("price_at_order") @db.Decimal(10, 2)
  totalPrice   Decimal @map("total_price") @db.Decimal(10, 2)

  // Relations
  order    Order    @relation(fields: [orderId], references: [orderId], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [menuItemId], onDelete: Cascade)

  @@index([orderId])
  @@index([menuItemId])
  @@map("order_items")
}

enum UserRole {
  patient
  nutritionist
  food_partner
  admin
}

enum GenderType {
  male
  female
  other
}

enum VerificationStatus {
  pending
  approved
  rejected
}

enum AppointmentType {
  online
}

enum AppointmentStatus {
  pending
  confirmed
  completed
  cancelled
}

enum MessageType {
  text
  image
  food_card
}

enum OrderStatus {
  PENDING
  PREPARING
  SHIPPING
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}
